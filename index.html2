                </div>
                <div class="text-right text-sm font-bold mb-6" id="progress-text">0 / 5 完了</div>

                <div class="space-y-3 mb-8">
                    <label class="checklist-item flex items-center p-4 bg-white/10 hover:bg-white/20 rounded-xl cursor-pointer transition-colors border border-white/10">
